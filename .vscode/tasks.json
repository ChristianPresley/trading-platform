{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Desk TUI",
            "detail": "Build the Trading Desk TUI in debug mode",
            "type": "shell",
            "command": "zig build build-desk-tui",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build Desk TUI (Release)",
            "detail": "Build the Trading Desk TUI with release-fast optimizations",
