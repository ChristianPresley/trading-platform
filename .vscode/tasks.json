{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Desk",
            "type": "shell",
            "command": "zig build build-desk",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Build Desk (Release)",
            "type": "shell",
            "command": "zig build build-desk -Doptimize=ReleaseFast",
            "group": "build",
            "problemMatcher": "$gcc",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Run Desk",
            "type": "shell",
            "command": "zig build run-desk",
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            }
        },
        {
            "label": "Test Desk",
            "type": "shell",
            "command": "zig build test-desk",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
